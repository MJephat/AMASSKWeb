@page "/sponsor"
@using System.Text.Json
@inject HttpClient Http

<PageTitle>Sponsors</PageTitle>

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0">
            <i class="fa-solid fa-handshake me-2"></i> Sponsors
        </h4>
        <small class="text-muted">Manage sponsor records</small>
    </div>

    <button class="btn text-white" style="background-color:#CD7F32" @onclick="ShowAddModal">
        <i class="fa-solid fa-plus me-2"></i> Add Sponsor
    </button>
</div>

<!-- Card -->
<div class="card shadow-sm p-3">

    <!-- Search -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <input type="text"
               class="form-control w-25"
               placeholder="Search by company name..."
               @bind="searchTerm" />
    </div>

    <!-- Loading -->
    @if (isLoading)
    {
        <div class="text-center mt-3">
            <div class="spinner-border text-secondary"></div>
            <p class="mt-2">Loading sponsors...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }
    else if (sponsors.Count == 0)
    {
        <div class="text-center text-muted py-4">
            No sponsors found.
        </div>
    }
    else
    {
        <!-- Cards -->
        <div class="row">
            @foreach (var sponsor in filteredSponsors)
            {
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm h-100 text-center p-3 sponsor-card"
                         style="cursor:pointer"
                         @onclick="() => OpenVisitsModal(sponsor)">

                        <img src="@sponsor.ImageUrl"
                             style="height:120px; object-fit:contain;" />

                        <div class="card-body">
                            <h6>@sponsor.CompanyName</h6>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@* display visit *@
@if (ShowVisitsModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">
                        @SelectedSponsorName Visits
                    </h5>

                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">

                    <!-- Count -->
                    <div class="mb-3">
                        <span class="badge bg-dark">
                            Total Attendees: @VisitList.Count
                        </span>
                    </div>

                    @if (IsLoadingVisits)
                    {
                        <p>Loading visits...</p>
                    }
                    else if (!VisitList.Any())
                    {
                        <p class="text-muted">No visits found.</p>
                    }
                    else
                    {
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in VisitList)
                                {
                                    <tr>
                                        <td>@v.VisitorName</td>
                                        <td>@v.VisitorEmail</td>
                                        <td>@v.VisitDateTime.ToLocalTime()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseAllModals">
                        Close
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@* add sponsor *@
@if (ShowModal)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title">Add Sponsor</h5>
                    <button class="btn-close" @onclick="CloseAllModals"></button>
                </div>

                @* <div class="mb-3">
                    <label class="form-label">Sponsor Unique Id</label>
                    <input class="form-control"
                           @bind="newSponsor.SponsorUniqueId" />
                </div> *@
                <!-- Body -->
                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Company Name</label>
                        <input class="form-control" @bind="newSponsor.CompanyName" />
                    </div>

                    <div class="mb-3">
                        <label>Upload Image</label>
                        <InputFile OnChange="HandleFileSelected" />
                    </div>
                    @if (string.IsNullOrEmpty(newSponsor.LogoBlobName))
                    {
                        <small class="text-warning">Upload image first</small>
                    }
                    else
                    {
                        <small class="text-success">Image ready</small>
                    }

                    @if (imagePreview != null)
                    {
                        <img src="@imagePreview" style="max-height:200px" />
                    }

                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-control" @bind="newSponsor.Category">
                            @foreach (var c in Enum.GetValues<SponsorCategory>())
                            {
                                <option value="@c">@c.ToString()</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Industry</label>
                        <select class="form-control" @bind="newSponsor.Industry">
                            @foreach (var i in Enum.GetValues<SponsorIndustry>())
                            {
                                <option value="@i">@i.ToString()</option>
                            }
                        </select>
                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseAllModals">Cancel</button>

                    <button class="btn btn-success"
                            @onclick="AddSponsor"
                            >
                        Save
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    private List<SponsorModel> sponsors = new();
    private bool isLoading = true;
    private string errorMessage = "";
    private bool isSaving = true;

    public string Container = "sskdevtests";
    string? imagePreview;

    private string SelectedSponsorId;
    private string EventId = "ssk-annual-congress-2026";

    private bool IsLoadingVisits = false;
    private List<BoothVisit> VisitList = new();

    private bool ShowVisitsModal = false;

    private string SelectedSponsorName;
    private bool ShowModal = false;

    private string searchTerm = "";

    /// <summary>
    //search through
    /// </summary> 
    private IEnumerable<SponsorModel> filteredSponsors =>
        string.IsNullOrWhiteSpace(searchTerm)
            ? sponsors
            : sponsors.Where(s => s.CompanyName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    private CreateSponsorRequest newSponsor = new()
        {
        LogoContainerName = "sskdevtests"
        };

    /// <summary>
    /// initializing
    /// </summary>

    protected override async Task OnInitializedAsync()
    {
        await LoadSponsors();
    }

    /// <summary>
    /// load sponsors
    /// </summary>
    private async Task LoadSponsors()
    {
        try
        {
            isLoading = true;
            errorMessage = "";

            var response = await Http.GetAsync(
                "https://bdn-ssk-events-api-e2gbegeqdfh6aedw.southafricanorth-01.azurewebsites.net/api/sponsors/all"
            );

            response.EnsureSuccessStatusCode();

            var json = await response.Content.ReadAsStringAsync();

            var result = JsonSerializer.Deserialize<ApiResponse<List<SponsorModel>>>
            (
                json,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                }
            );

            sponsors = result?.Data ?? new();

            foreach (var sponsor in sponsors)
            {
                sponsor.ImageUrl = await ResolveImageUrl(sponsor);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // =========================
    // LOAD visitors
    // =========================
    private async Task LoadVisits()
    {
        try
        {
            IsLoadingVisits = true;

            var url = $"https://bdn-ssk-events-api-e2gbegeqdfh6aedw.southafricanorth-01.azurewebsites.net/api/boothvisits/{SelectedSponsorId}/event?eventId={EventId}";

            var response = await Http.GetFromJsonAsync<ApiResponse<List<BoothVisit>>>(url);

            if (response != null && response.IsSuccess)
            {
                VisitList = response.Data ?? new();
            }
            else
            {
                VisitList = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            VisitList = new();
        }
        finally
        {
            IsLoadingVisits = false;
        }
    }

    // =========================
    // Handle image selection
    // =========================
    async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            var content = new MultipartFormDataContent();

            var stream = file.OpenReadStream(10 * 1024 * 1024);

            var fileContent = new StreamContent(stream);

            fileContent.Headers.ContentType =
                new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

            var blobName = file.Name;

            content.Add(fileContent, "image", blobName);

            var uploadUrl =
                $"api/UploadImage?blobName={Uri.EscapeDataString(blobName)}&containerName={Container}";

            var response = await Http.PostAsync(uploadUrl, content);

            response.EnsureSuccessStatusCode();

            var result =
                await response.Content.ReadFromJsonAsync<UploadBlobResponseDTO>();

            Console.WriteLine($"Uploaded blob: {result?.BlobName}");

            // ✅ MAP upload response to sponsor request
            newSponsor.LogoBlobName = result?.BlobName;
            newSponsor.LogoContainerName = result?.ContainerName;

            // preview
            using var ms = new MemoryStream();

            await file.OpenReadStream().CopyToAsync(ms);

            imagePreview =
                $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    // =========================
    // Add  sponsor
    // =========================
    private async Task AddSponsor()
    {
        try
        {
            isSaving = true;

            Console.WriteLine("===== ADD SPONSOR START =====");

            Console.WriteLine($"CompanyName: {newSponsor.CompanyName}");
            Console.WriteLine($"SponsorId: {newSponsor.SponsorUniqueId}");
            Console.WriteLine($"BlobName: {newSponsor.LogoBlobName}");
            Console.WriteLine($"Container: {newSponsor.LogoContainerName}");

            var payload = new
            {
                id = "",
                sponsorUniqueId = newSponsor.SponsorUniqueId,
                companyName = newSponsor.CompanyName?.Trim(),
                logoBlobName = string.IsNullOrEmpty(newSponsor.LogoBlobName)
                                ? "default.png"
                                : newSponsor.LogoBlobName,
                logoContainerName = "sskdevtests",
                category = newSponsor.Category.ToString(),
                industry = newSponsor.Industry.ToString()
            };

            Console.WriteLine("Payload created");

            var response = await Http.PostAsJsonAsync(
                "https://bdn-ssk-events-api-e2gbegeqdfh6aedw.southafricanorth-01.azurewebsites.net/api/sponsors",
                payload
            );

            Console.WriteLine($"Status Code: {response.StatusCode}");

            var responseBody = await response.Content.ReadAsStringAsync();

            Console.WriteLine("===== API RESPONSE =====");
            Console.WriteLine(responseBody);

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine("Sponsor added successfully");

                await LoadSponsors();

                Console.WriteLine($"Sponsors count after refresh: {sponsors.Count}");

                imagePreview = null;

                CloseAllModals();

                StateHasChanged();
            }
            else
            {
                errorMessage = responseBody;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("===== ERROR =====");
            Console.WriteLine(ex.ToString());

            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;

            Console.WriteLine("===== ADD SPONSOR END =====");
        }
    }
 


    // =========================
    // get image url
    // =========================
    private async Task<string> ResolveImageUrl(SponsorModel sponsor)
    {
        // case 1: already full URL
        if (!string.IsNullOrWhiteSpace(sponsor.LogoBlobName) &&
            sponsor.LogoBlobName.StartsWith("http"))
        {
            return sponsor.LogoBlobName;
        }

        // case 2: fetch SAS URL from backend
        try
        {
            var url =
                $"https://aura-amassk-backend-fxcah5dkbpexc2gn.southafricanorth-01.azurewebsites.net/api/GetImageByBlobName" +
                $"?containerName={Uri.EscapeDataString(sponsor.LogoContainerName)}" +
                $"&blobName={Uri.EscapeDataString(sponsor.LogoBlobName)}";

            var result =
                await Http.GetFromJsonAsync<ApiResponse<string>>(url);

            return result?.Data ?? "images/no-image.png";
        }
        catch
        {
            return "images/no-image.png";
        }
    }

    // =========================
    // opening modals
    // =========================
    private async Task OpenVisitsModal(SponsorModel sponsor)
    {
        SelectedSponsorId = sponsor.SponsorUniqueId;
        SelectedSponsorName = sponsor.CompanyName;

        ShowVisitsModal = true;

        await LoadVisits();
    }

   

    private void ShowAddModal()
    {
        ShowModal = true;
    }

    private void CloseAllModals()
    {
        ShowModal = false;
        ShowVisitsModal = false;

        VisitList.Clear();

        newSponsor = new CreateSponsorRequest
        {
            LogoContainerName = "sskdevtests"
        };
    }

    public enum SponsorCategory
    {
        Platinum = 1,
        Gold = 2,
        Silver = 3,
        Bronze = 4,
        Other = 5
    }

    public enum SponsorIndustry
    {
        Pharma,
        Automotive,
        Retail,
        Furniture,
        Food,
        Hospitality,
        Holiday,
        RealEstate,
        Education,
        Fashion
    }

    public class ApiResponse<T>
    {
        public bool IsSuccess { get; set; }
        public string? ErrorMessage { get; set; }
        public T Data { get; set; }
    }

    public class SponsorModel
    {
        public string Id { get; set; }
        public string SponsorUniqueId { get; set; }
        public string CompanyName { get; set; }
        public string LogoBlobName { get; set; }
        public string LogoContainerName { get; set; }

        public int Category { get; set; }
        public int Industry { get; set; }

        public string ImageUrl { get; set; }
    }

    public class BoothVisit
    {
        public string Id { get; set; }
        public string UniqueEventIdentifier { get; set; }
        public string SponsorUniqueId { get; set; }
        public string VisitorName { get; set; }
        public string VisitorEmail { get; set; }
        public DateTime VisitDateTime { get; set; }
    }

    public class CreateSponsorRequest
    {
        public string SponsorUniqueId { get; set; }
        public string CompanyName { get; set; }
        public string LogoBlobName { get; set; }
        public string LogoContainerName { get; set; } = "sskdevtests";
        public SponsorCategory Category { get; set; } = SponsorCategory.Platinum;
        public SponsorIndustry Industry { get; set; } = SponsorIndustry.Pharma;
    }

    public class UploadBlobResponseDTO
    {
        public string Message { get; set; }
        public string ContainerName { get; set; }
        public string BlobName { get; set; }
    }
}