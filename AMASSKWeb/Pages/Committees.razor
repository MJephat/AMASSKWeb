@page "/committees"
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="container my-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0">Committees</h3>
            <small class="text-muted">SSK committees and their mandates</small>
        </div>

        <button class="btn add-btn px-4" @onclick="OpenCreateModal">
            + Add Committee
        </button>
    </div>

    <!-- Committees Grid -->
    <div class="row g-4">

        @foreach (var committee in committees)
        {
            <div class="col-md-6">
                <div class="card committee-card h-100">
                    <div class="card-body d-flex flex-column justify-content-between">

                        <!-- Top Section -->
                        <div class="d-flex justify-content-between align-items-start">

                            <!-- Left: Icon + Info -->
                            <div class="d-flex">

                                <!-- Icon -->
                                <div class="committee-icon me-3">
                                    <i class="@GetCommitteeIcon(committee.Type)"></i>
                                </div>

                                <!-- Text -->
                                <div>
                                    <h6 class="fw-bold mb-1">@committee.Title</h6>

                                    <small class="text-muted d-block mb-1">
                                        @GetCommitteeTypeLabel(committee.Type)
                                    </small>

                                    <small class="text-muted">
                                        Chairman: <b>@committee.Chair</b>
                                    </small>
                                </div>
                            </div>

                            <!-- Right: Delete -->
                            <button class="btn btn-sm btn-light text-danger border-0"
                                    title="Delete"
                                    @onclick="() => ConfirmDelete(committee)">
                                <i class="bi bi-trash"></i>
                            </button>

                        </div>

                        <!-- Bottom Section -->
                        <div class="mt-3 d-flex justify-content-between align-items-center">

                            <!-- Members Count -->
                            <small class="text-muted">
                                @committee.Items.Count Members
                            </small>

                            <button class="btn members-btn"
                                    @onclick="() => OpenApplications(committee)">
                                <i class="bi bi-person-lines-fill"></i> Applications
                            </button>

                            <!-- View Button -->
                            <button class="btn members-btn"
                                    @onclick="() => ShowMembers(committee)">
                                <i class="bi bi-people-fill me-1"></i>
                                View
                            </button>

                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
</div>

@* madal show members *@
@if (selectedCommittee != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@selectedCommittee.Title Members</h5>
                    <button class="btn-close" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body">

                    @if (selectedCommittee.Items.Any())
                    {
                        <ul class="list-group">
                            @foreach (var member in selectedCommittee.Items)
                            {
                                <li class="list-group-item">
                                    <i class="bi bi-person me-2"></i> @member
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No members found.</p>
                    }

                </div>
                <div class="mb-3">
                    <input class="form-control"
                           placeholder="Enter member email"
                           @bind="newMemberEmail" />

                    
                </div>

                <div class="modal-footer">
                    <button class="members-btn"
                            @onclick="AddMemberToSelected">
                        Add Member
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>

            </div>
        </div>
    </div>
}


@* create madal *@
@if (showCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Create Committee</h5>
                    <button class="btn-close" @onclick="CloseCreateModal"></button>
                </div>

                <div class="modal-body">

                    <!-- Committee Name -->
                    <div class="mb-3">
                        <label class="form-label">Committee Name</label>
                        <input class="form-control"
                               @bind="newCommittee.FriendlyName" />
                    </div>

                    <!-- Type -->
                    <div class="mb-3">
                        <label class="form-label">Committee Type</label>
                        <select class="form-select" @bind="newCommittee.Type">
                            @foreach (var type in Enum.GetValues<CommitteeType>())
                            {
                                <option value="@type">@GetCommitteeTypeLabel(type)</option>
                            }
                        </select>
                    </div>

                    <!-- Chairman -->
                    <div class="mb-3">
                        <label class="form-label">Chairman Email</label>
                        <input class="form-control"
                               @bind="newCommittee.ChairmanEmail" />
                    </div>

                    <!-- Members -->
                    <div class="mb-3">
                        <label class="form-label">Members (comma separated)</label>
                        <textarea class="form-control"
                                  @bind="membersInput"></textarea>
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                    <button class="btn btn-warning text-white"
                            @onclick="CreateCommittee"
                            disabled="@isCreating">
                        @(isCreating ? "Creating..." : "Create")
                    </button>
                </div>

            </div>
        </div>
    </div>
}

