@page "/chapters"
@using System.Text.Json.Serialization
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject HttpClient Http

<PageTitle>Chapters</PageTitle>

<div class="container">

    <!-- Header -->
    <div class="header">
        <div>
            <h2>Chapters</h2>
            <small>Regional chapter meetings & schedules</small>
        </div>

        <button class="btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#createChapterModal">
            <i class="bi bi-plus-lg"></i> Add Chapter
        </button>
    </div>

    @if (isLoading)
    {
        <p>Loading chapters...</p>
    }
    else if (ChapterList == null || !ChapterList.Any())
    {
        <p>No chapters found.</p>
    }
    else
    {
        <!-- Cards Grid -->
        <div class="chapters-grid">
            @foreach (var chapter in ChapterList)
            {
                <div class="chapter-card">

                    <div class="card-top">
                        <div class="location">
                            <i class="bi bi-geo-alt"></i>
                            <strong>@chapter.Name</strong>
                        </div>

                        <span class="badge @GetBadgeClass(chapter.Status)">
                            @chapter.Status
                        </span>
                    </div>

                    <div class="card-body">
                       <div>
                            <i class="bi bi-gear" style="font-style:italic"></i>
                        @chapter.Admin
                    </div>
                        <div>
                            <i class="bi bi-calendar-event"></i>
                            @chapter.Schedule
                        </div>

                        <div>
                            <i class="bi bi-clock"></i>
                            @chapter.Time
                        </div>
                    </div>
                    

                    <div class="card-footer">
                        <span>
                            <i class="bi bi-calendar-check"></i>
                            Next: @chapter.NextDate
                        </span>

                        <span class="clickable"
                              data-bs-toggle="modal"
                              data-bs-target="#membersModal"
                              @onclick="() => SetMembers( chapter.Name)">
                            <i class="bi bi-people"></i>
                            @chapter.Members members
                        </span>

                        <button class="btn btn-sm "
                                @onclick="() => DeleteChapter(chapter.GeoRegion)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>

                </div>
            }
        </div>
    }
</div>

@* get members list *@
<div class="modal fade" id="membersModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Chapter Members for @SelectedChapterName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                @if (SelectedMembers != null && SelectedMembers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    @* <th>#</th> *@
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Reg</th>
                                    <th>Phone</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in SelectedMembers.Select((value, index) => new { value, index }))
                                {
                                    <tr>
                                        @* <td>@(member.index + 1)</td> *@
                                        <td>
                                            <small>@member.value.FullNames</small>
                                        </td>
                                        <td>@member.value.Email</td>
                                        <td>@member.value.RegistrationNumber</td>
                                        <td>@member.value.PhoneNumber</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No members found.</p>
                }
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Close
                </button>
            </div>

        </div>
    </div>
</div>

@* create chapter *@
<div class="modal fade" id="createChapterModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Create Chapter</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="mb-3">
                    <label>Region</label>
                    @if (string.IsNullOrWhiteSpace(NewChapter.GeoRegion))
                    {
                        <small class="text-danger">Region is required</small>
                    }
                    <select class="form-select" @bind="NewChapter.GeoRegion">
                        <option value="">-- Select Region --</option>

                        @foreach (var region in Regions)
                        {
                            <option value="@region">@region</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label>Admin Email</label>
                    <input class="form-control" @bind="NewChapter.AdminEmail" />
                </div>

                <div class="mb-3">
                    <label>Members (comma separated)</label>
                    <textarea class="form-control" @bind="MembersInput"></textarea>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateChapter">Create</button>
            </div>

        </div>
    </div>
</div>

@code {

    List<Chapter> ChapterList = new();
    bool isLoading = true;

    List<MemberDto> SelectedMembers = new();

    // List<string> SelectedMembers = new();
    bool showMembersModal = false;

    //setting memnbers
    string SelectedChapterName = "";
    CreateChapterRequest NewChapter = new();
    string MembersInput = "";

    List<string> Regions = new()
{
      "Coast",
      "Central",
      "Nairobi",
      "SouthRift",
      "NorthRift",
      "Northern",
      "Eastern",
      "WesternNyanza"
};

    // void SetMembers(List<string> members, string chapterName)
    // {
    //     SelectedMembers = members ?? new List<string>();
    //     SelectedChapterName = chapterName;

    // }

    //get the count and names of members per chapter
    async Task SetMembers(string chapterName)
    {
        SelectedChapterName = chapterName;

        try
        {
            var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"api/GetMembersByChapter?chapter={chapterName}"
            );

            request.Headers.Add("Authorization", $"Bearer {AuthState.Token}");

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<List<MemberDto>>>();

                if (result?.IsSuccess == true)
                {
                    SelectedMembers = result.Data ?? new List<MemberDto>();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    //count members helper
    async Task<int> GetMemberCount(string chapterName)
    {
        try
        {
            var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"api/GetMembersByChapter?chapter={chapterName}"
            );

            request.Headers.Add("Authorization", $"Bearer {AuthState.Token}");

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<List<MemberDto>>>();

                if (result?.IsSuccess == true)
                {
                    return result.Data?.Count ?? 0;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

        return 0;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsLoggedIn)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<ChapterDto>>>("api/GetChapters");

            if (response?.IsSuccess == true)
            {
                var tasks = response.Data.Select(async x =>
{
    var chapterName = GetRegionName(x.GeoRegion);
    var count = await GetMemberCount(chapterName);

    return new Chapter
                        {
                            Name = chapterName,
                            GeoRegion = chapterName,
                            Admin = x.AdminEmail,
                            Schedule = "TBD",
                            Time = "TBD",
                            NextDate = "TBD",
                            Members = count,
                            Status = "Active"
                        };
                    });

                ChapterList = (await Task.WhenAll(tasks)).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    //create new Chapter
    async Task CreateChapter()
    {
        if (string.IsNullOrWhiteSpace(NewChapter.GeoRegion))
            return;

        try
        {
            NewChapter.Members = MembersInput
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(x => x.Trim())
                .ToList();

            var response = await Http.PostAsJsonAsync("api/CreateChapter", NewChapter);

            if (response.IsSuccessStatusCode)
            {
                NewChapter = new CreateChapterRequest();
                MembersInput = "";

                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    //delete
    async Task DeleteChapter(string region)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/DeleteChapter?geoRegion={region}");

            if (response.IsSuccessStatusCode)
            {
                // Refresh list after delete
                await OnInitializedAsync();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine(error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    //regions
    string GetRegionName(int region)
    {
        return region switch
        {
            0 => "Coast",
            1 => "Central",
            2 => "Nairobi",
            3 => "SouthRift",
            4 => "NorthRift",
            5 => "Northern",
            6 => "Eastern",
            7 => "WesternNyanza"
        };
    }

    //status
    string GetBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "badge-active",
            "Coming Soon" => "badge-coming",
            "Planning" => "badge-planning",
            _ => ""
        };
    }



    // UI Model (what your page actually uses)
    public class Chapter
    {
        public string Name { get; set; }
        public string GeoRegion { get; set; }  // 👈 ADD THIS
        public string Schedule { get; set; }
        public string Admin { get; set; }
        public string Time { get; set; }
        public string NextDate { get; set; }
        public int Members { get; set; }
        public string Status { get; set; }
        public List<string> MemberEmails { get; set; } = new();
    }

    // API Wrapper
    public class ApiResponse<T>
    {
        public bool IsSuccess { get; set; }
        public string ErrorMessage { get; set; }
        public T Data { get; set; }
    }

    // API DTO (exactly from backend)
    public class ChapterDto
    {
        public string Id { get; set; }
        public int GeoRegion { get; set; }
        public string AdminEmail { get; set; }
        public List<string> Members { get; set; }
    }
    public class CreateChapterRequest
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string GeoRegion { get; set; }
        public string AdminEmail { get; set; }
        public List<string> Members { get; set; } = new();
    }

    public class MemberDto
    {
        public string Id { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string RegistrationNumber { get; set; }
        public string Email { get; set; }
        public string PhoneNumber { get; set; }
        public string FullNames { get; set; }
    }
}