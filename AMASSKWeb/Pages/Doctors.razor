@page "/doctors"
@inject HttpClient Http
@inject AuthState AuthState
@inject NavigationManager Navigation

<h3 class="mb-4">Doctors Directory</h3>

@if (isLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-secondary"></div>
        <p class="mt-2">Loading doctors...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="row" style="min-height:600px;">

        <!-- LEFT SIDE - TABLE -->
        <div class="col-md-5 border-end">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Reg No</th>
                            <th>Location</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doctor in doctors)
                        {
                            <tr style="cursor:pointer;"
                                class="@(selectedDoctor?.Email == doctor.Email ? "table-active" : "")"
                                @onclick="() => LoadProfile(doctor)">
                                <td class="fw-semibold">@doctor.FullNames</td>
                                <td>@doctor.RegistrationNumber</td>
                                <td>@doctor.Location</td>
                                <td>
                                    <span class="badge bg-secondary">@doctor.IcpdPoints</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- RIGHT SIDE - PROFILE -->
        <div class="col-md-7">
            @if (selectedDoctor == null && !profileNotFound)
            {
                <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                    <h5>Select a doctor to view profile</h5>
                </div>
            }
            else if (profileNotFound)
            {
                <div class="d-flex justify-content-center align-items-center h-100 text-danger">
                    <h5>No profile found for the selected doctor</h5>
                </div>
            }
            else
            {
                <div class="card shadow-sm p-4">
                    <div class="row">
                        <div class="col-md-4 text-center">
                            <img src="@photoUrl"
                                 class="img-fluid rounded-circle shadow-sm"
                                 style="width:180px;height:180px;object-fit:cover;"
                                 onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=@(selectedDoctor.FirstName)+@(selectedDoctor.LastName)&background=CD7F32&color=fff';" />

                            @* voter elegibility *@

                            <button class="btn btn-sm @(selectedDoctor.canVote ? "btn-danger" : "btn-success")"
                                    @onclick="ToggleVoting">
                                @(selectedDoctor.canVote ? "Can't Vote" : "Can Vote")
                            </button>
                        </div>


                        <div class="col-md-8">
                            <h4 class="fw-bold mb-1">@selectedDoctor.FirstName @selectedDoctor.LastName</h4>
                            <p class="text-muted mb-2">@selectedDoctor.Email</p>
                            <p class="text-muted mb-2">@selectedDoctor.Specialty</p>
                            <p>@selectedDoctor.Details</p>

                            <hr />
                            <h6>Facilities</h6>
                            @if (selectedDoctor.Facilities?.Any() == true)
                            {
                                <ul>
                                    @foreach (var facility in selectedDoctor.Facilities)
                                    {
                                        <li>@facility</li>
                                    }
                                </ul>
                            }

                            <p class="mt-3"><strong>Region:</strong> @selectedDoctor.Region</p>
                            <p><strong>Phone:</strong> @selectedDoctor.PhoneNumber</p>
                         

                            @if (qualificationPdfUrls.Any())
                            {
                                <div class="mt-3">
                                    <strong>Qualification Documents</strong>
                                    <ul class="mt-2">
                                        @foreach (var pdf in qualificationPdfUrls)

                                        {
                                            var rawName = Path.GetFileName(new Uri(pdf).LocalPath);
                                            var nameWithoutExt = Path.GetFileNameWithoutExtension(rawName);

                                            var cleanName = nameWithoutExt
                                            .Replace("_", " ")
                                            .Replace("-", " ");

                                            // Capitalize words
                                            cleanName = System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(cleanName);

                                            <li>
                                                <a href="@pdf" target="_blank" class="text-decoration-none">
                                                    @cleanName
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mt-2">No qualification documents found.</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Doctor> doctors = new();
    private DoctorProfile? selectedDoctor;
    private Doctor? selectedDoctorFromTable; // holds registration number
    private bool isLoading = true;
    private string? errorMessage;
    private bool profileNotFound;

    private List<string> qualificationBlobNames = new();
    private List<string> qualificationPdfUrls = new();
    private string photoUrl = "/images/default-doctor.png";

    private string? currentElectionIdentifier;

    protected override void OnInitialized()
    {
        if (!AuthState.IsLoggedIn)
            Navigation.NavigateTo("/", true);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadActiveElection();

            var response = await Http.GetFromJsonAsync<ApiResponse>("api/GetFullMembers");

            if (response?.IsSuccess == true && response.Data != null)
                doctors = response.Data;
            else
                errorMessage = response?.ErrorMessage ?? "Failed to load doctors.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }


    private async Task LoadActiveElection()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ElectionApiResponse>("api/GetElections?onlyActive=true");

            if (response?.IsSuccess == true && response.Data?.Any() == true)
            {
                currentElectionIdentifier = response.Data.First().ElectionIdentifier;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading election: " + ex.Message);
        }
    }

    // voting toggle
    private async Task ToggleVoting()
    {
        if (selectedDoctor == null || selectedDoctorFromTable == null)
            return;

        try
        {
            var newStatus = !selectedDoctor.canVote;

            var requestData = new UpdateDoctorVotingStatusRequest
            {
                Id = selectedDoctorFromTable.RegistrationNumber,
                Email = selectedDoctor.Email,
                CanVote = newStatus
            };

            // ✅ FIX: Use correct API route (very likely this)
            var response = await Http.PostAsJsonAsync(
                "api/UpdateDoctorVotingStatus",
                requestData
            );

            response.EnsureSuccessStatusCode();

            selectedDoctor.canVote = newStatus;

            var result = await response.Content.ReadAsStringAsync();
            Console.WriteLine(result);
        }
        catch (Exception ex)
        {
            Console.WriteLine("ToggleVoting error: " + ex.Message);
        }
    }

    private async Task LoadProfile(Doctor doctorFromTable)
    {
        selectedDoctorFromTable = doctorFromTable;
        profileNotFound = false;
        selectedDoctor = null;
        qualificationBlobNames.Clear();
        qualificationPdfUrls.Clear();
        photoUrl = "/images/default-doctor.png";

        try
        {
            var response = await Http.GetAsync($"api/GetMemberProfile?email={Uri.EscapeDataString(doctorFromTable.Email)}");

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                profileNotFound = true;
                return;
            }

            response.EnsureSuccessStatusCode();
            var profile = await response.Content.ReadFromJsonAsync<ProfileResponse>();

            if (profile?.IsSuccess == true && profile.Data != null)
            {
                selectedDoctor = profile.Data;
                photoUrl = await GetPhotoUrlAsync(selectedDoctor);

                // Pass registration number from table model
                await LoadQualificationDocuments(doctorFromTable.RegistrationNumber);
            }
            else
            {
                profileNotFound = true;
            }
        }
        catch
        {
            profileNotFound = true;
        }
    }

    private async Task<string> GetPhotoUrlAsync(DoctorProfile doctor)
    {
        if (string.IsNullOrWhiteSpace(doctor.PhotoBlobName) || string.IsNullOrWhiteSpace(doctor.PhotoBlobContainer))
            return "/images/default-doctor.png";

        try
        {
            var url = $"api/GetImageByBlobName?containerName={doctor.PhotoBlobContainer}&blobName={Uri.EscapeDataString(doctor.PhotoBlobName)}";
            var response = await Http.GetFromJsonAsync<BlobImageResponse>(url);
            if (response?.IsSuccess == true && !string.IsNullOrEmpty(response.Data))
                return response.Data;
        }
        catch { }

        return "/images/default-doctor.png";
    }

    private async Task LoadQualificationDocuments(string registrationNumber)
    {
        if (selectedDoctor == null || string.IsNullOrWhiteSpace(registrationNumber))
            return;

        try
        {
            var url = $"api/GetDoctorQualificationDocuments?email={Uri.EscapeDataString(selectedDoctor.Email)}&registrationNumber={Uri.EscapeDataString(registrationNumber)}";

            var response = await Http.GetFromJsonAsync<BlobListResponse>(url);

            if (response?.IsSuccess == true && response.Data != null)
            {
                qualificationBlobNames = response.Data;
                await LoadPdfUrls();
            }
            else
            {
                Console.WriteLine("Error loading documents: " + response?.ErrorMessage);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Exception loading qualification documents: " + ex.Message);
        }
    }



    private async Task LoadPdfUrls()
    {
        qualificationPdfUrls.Clear();
        foreach (var blob in qualificationBlobNames)
        {
            try
            {
                var url = $"api/GetPDFByBlobName?containerName=sskdoctorqualifications&blobName={Uri.EscapeDataString(blob)}";
                var response = await Http.GetFromJsonAsync<PdfResponse>(url);
                if (response?.IsSuccess == true && !string.IsNullOrWhiteSpace(response.Data))
                    qualificationPdfUrls.Add(response.Data);
                else
                    Console.WriteLine("Failed to get PDF URL for blob: " + blob);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Exception getting PDF URL for blob: " + blob + " - " + ex.Message);
            }
        }
    }

    // ===== Models =====
    public class Doctor {
        public string Id { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string RegistrationNumber { get; set; }
        public string Email { get; set; }
        public string Location { get; set; } 
        public int IcpdPoints { get; set; } 
        public string FullNames { get; set; } 
    }
    public class ApiResponse {
        public bool IsSuccess { get; set; } 
        public string? ErrorMessage { get; set; } 
        public List<Doctor>? Data { get; set; } 
    }
    public class DoctorProfile {
        public string Id { get; set; }
        public string Email { get; set; } 
        public string FirstName { get; set; } 
        public string LastName { get; set; } 
        public string PhoneNumber { get; set; }
        public string Specialty { get; set; } 
        public string Details { get; set; } 
        public List<string>? Facilities { get; set; } 
        public string Region { get; set; } 
        public string PhotoBlobName { get; set; } 
        public string PhotoBlobContainer { get; set; } 
        public bool canVote { get; set; }
    }
    public class ProfileResponse {
        public bool IsSuccess { get; set; } 
        public string? ErrorMessage { get; set; } 
        public DoctorProfile? Data { get; set; } 
    }
    public class BlobImageResponse { 
        public bool IsSuccess { get; set; } 
        public string? ErrorMessage { get; set; }
        public string? Data { get; set; } 
    }
    public class BlobListResponse {
        public bool IsSuccess { get; set; }
        public string ErrorMessage { get; set; }
        public List<string> Data { get; set; } 
    }
    public class PdfResponse {
        public bool IsSuccess { get; set; }
        public string ErrorMessage { get; set; } 
        public string Data { get; set; } 
    }
    public class ElectionApiResponse
    {
        public bool IsSuccess { get; set; }
        public string ErrorMessage { get; set; }
        public List<ElectionDto> Data { get; set; }
    }

    public class ElectionDto
    {
        public string? ElectionIdentifier { get; set; }
    }
    public class UpdateDoctorVotingStatusRequest
    {
        public string Id { get; set; }
        public string Email { get; set; }
        public bool CanVote { get; set; }
    }
}