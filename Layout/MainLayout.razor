@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <button class="btn btn-outline-danger"
                    @onclick="Logout">
                Logout
            </button>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;

    void Logout()
    {
        Nav.NavigateTo("/", true);
    }
}