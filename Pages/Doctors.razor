@page "/doctors"
@inject HttpClient Http

<h3 class="mb-4">Doctors Directory</h3>

@if (isLoading)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-secondary"></div>
        <p class="mt-2">Loading doctors...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="row" style="min-height:600px;">

        <!-- LEFT SIDE - TABLE -->
        <div class="col-md-5 border-end">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Reg No</th>
                            <th>Location</th>
                            <th>Points</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var doctor in doctors)
                        {
                            <tr style="cursor:pointer;"
                                class="@(selectedDoctor?.Email == doctor.Email ? "table-active" : "")"
                                @onclick="() => LoadProfile(doctor.Email)">

                                <td class="fw-semibold">@doctor.FullNames</td>
                                <td>@doctor.RegistrationNumber</td>
                                <td>@doctor.Location</td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @doctor.IcpdPoints
                                    </span>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>


        <!-- RIGHT SIDE - PROFILE -->
        <div class="col-md-7">

            @if (selectedDoctor == null)
            {
                <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                    <h5>Select a doctor to view profile</h5>
                </div>
            }
            else
            {
                <div class="card shadow-sm p-4">

                    <div class="row">
                        <div class="col-md-4 text-center">
                            <img src="@GetPhotoUrl(selectedDoctor)"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-height:220px;" />

                        </div>

                        <div class="col-md-8">

                            <h4 class="fw-bold mb-1">
                                @selectedDoctor.FirstName @selectedDoctor.LastName
                            </h4>
                            <p class="text-muted mb-2">
                               
                                @selectedDoctor.Email
                            </p>
                            <p class="text-muted mb-2">
                                @selectedDoctor.Specialty
                            </p>

                            <p>@selectedDoctor.Details</p>

                            <hr />

                            <h6>Facilities</h6>

                            @if (selectedDoctor.Facilities != null)
                            {
                                <ul>
                                    @foreach (var facility in selectedDoctor.Facilities)
                                    {
                                        <li>@facility</li>
                                    }
                                </ul>
                            }

                            <p class="mt-3">
                                <strong>Region:</strong> @selectedDoctor.Region
                            </p>

                            <p>
                                <strong>Phone:</strong> @selectedDoctor.PhoneNumber
                            </p>

                        </div>
                    </div>

                </div>
            }

        </div>

    </div>
}

@code {

    private List<Doctor> doctors = new();
    private DoctorProfile? selectedDoctor;
    private bool isLoading = true;
    private string? errorMessage;

// getting Doctors
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse>(
                "https://aura-amassk-backend-fxcah5dkbpexc2gn.southafricanorth-01.azurewebsites.net/api/GetDoctors");

            if (response != null && response.IsSuccess && response.Data != null)
            {
                doctors = response.Data;
            }
            else
            {
                errorMessage = response?.ErrorMessage ?? "Failed to load doctors.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // loading profiles
    private async Task LoadProfile(string email)
    {
        try
        {
            selectedDoctor = null;

            var response = await Http.GetFromJsonAsync<ProfileResponse>(
                $"https://aura-amassk-backend-fxcah5dkbpexc2gn.southafricanorth-01.azurewebsites.net/api/GetDoctorProfile?email={email}");

            if (response != null && response.IsSuccess)
            {
                selectedDoctor = response.Data;
            }
            else
            {
                errorMessage = response?.ErrorMessage ?? "Failed to load profile.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    //getting profile pictures

    // private string GetPhotoUrl(DoctorProfile doctor)
    // {
    //     if (string.IsNullOrWhiteSpace(doctor.PhotoBlobName))
    //         return "images/default-doctor.png";

    //     return $"https:doctor-profile-photos.blob.core.windows.net/{doctor.PhotoBlobContainer}/{doctor.PhotoBlobName}";
    // }
    private string GetPhotoUrl(DoctorProfile doctor)
    {
        if (string.IsNullOrWhiteSpace(doctor.PhotoBlobName))
            return $"https://i.pravatar.cc/150?u={doctor.Email}";

        var storageAccount = "fimeventimages"; // YOUR REAL STORAGE ACCOUNT NAME

        return $"https://{storageAccount}.blob.core.windows.net/{doctor.PhotoBlobContainer}/{doctor.PhotoBlobName}";
    }

    // ===== LIST MODEL =====
    public class Doctor
    {
        public string Id { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string RegistrationNumber { get; set; }
        public string Email { get; set; }
        public string Location { get; set; }
        public int IcpdPoints { get; set; }
        public string FullNames { get; set; }
    }

    public class ApiResponse
    {
        public bool IsSuccess { get; set; }
        public string? ErrorMessage { get; set; }
        public List<Doctor>? Data { get; set; }
    }

    // ===== PROFILE MODEL =====
    public class DoctorProfile
    {
        public string Id { get; set; }
        public string Email { get; set; }
        public string FirstName { get; set; }
        public string LastName { get; set; }
        public string PhoneNumber { get; set; }
        public string Specialty { get; set; }
        public string Details { get; set; }
        public List<string>? Facilities { get; set; }
        public string Region { get; set; }
        public string PhotoBlobName { get; set; }
        public string PhotoBlobContainer { get; set; }
    }

    public class ProfileResponse
    {
        public bool IsSuccess { get; set; }
        public string? ErrorMessage { get; set; }
        public DoctorProfile? Data { get; set; }
    }
}