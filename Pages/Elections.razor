@page "/elections"

<PageTitle>Elections</PageTitle>

<div class="container">

    <!-- Header -->
    <div class="header">
        <div>
            <h2>Elections</h2>
            <small>Manage SSK 2026 General Elections</small>
        </div>

        <button class="btn-primary">
            + Create Election
        </button>
    </div>

    <!-- Election Card -->
    <div class="election-card">
        <div>
            <h4>SSK 2026 General Elections</h4>
            <small>Wednesday, 15 April 2026</small>
        </div>

        <span class="badge-progress">In Progress</span>
    </div>

    <!-- Results Board -->
    <div class="results-card">
        <h5>🏆 Results Board</h5>

        <table class="results-table">
            <thead>
                <tr>
                    <th>Position</th>
                    <th>Candidate</th>
                    <th>Votes</th>
                    <th>Percentage</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var position in Positions)
                {
                    foreach (var candidate in position.Candidates)
                    {
                        var leadingVotes = position.Candidates.Max(c => c.Votes);
                        var percentage = (candidate.Votes * 100.0) /
                        position.Candidates.Sum(c => c.Votes);

                        <tr>
                            <td>@position.Name</td>
                            <td>@candidate.Name</td>
                            <td>@candidate.Votes</td>
                            <td>@percentage.ToString("0.0") %</td>
                            <td>
                                @if (candidate.Votes == leadingVotes)
                                {
                                    <span class="badge-loading">Loading</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

</div>

@code {
    public class Candidate
    {
        public string Name { get; set; }
        public int Votes { get; set; }
    }

    public class Position
    {
        public string Name { get; set; }
        public List<Candidate> Candidates { get; set; }
