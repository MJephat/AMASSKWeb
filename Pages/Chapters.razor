@page "/chapters"

<PageTitle>Chapters</PageTitle>

<div class="container">

    <!-- Header -->
    <div class="header">
        <div>
            <h2>Chapters</h2>
            <small>Regional chapter meetings & schedules</small>
        </div>

        <button class="btn-primary">
            <i class="bi bi-plus-lg"></i> Add Chapter
        </button>
    </div>

    <!-- Cards Grid -->
    <div class="chapters-grid">
        @foreach (var chapter in ChapterList)
        {
            <div class="chapter-card">

                <div class="card-top">
                    <div class="location">
                        <i class="bi bi-geo-alt"></i>
                        <strong>@chapter.Name</strong>
                    </div>

                    <span class="badge @GetBadgeClass(chapter.Status)">
                        @chapter.Status
                    </span>
                </div>

                <div class="card-body">
                    <div>
                        <i class="bi bi-calendar-event"></i>
                        @chapter.Schedule
                    </div>

                    <div>
                        <i class="bi bi-clock"></i>
                        @chapter.Time
                    </div>
                </div>

                <div class="card-footer">
                    <span>
                        <i class="bi bi-calendar-check"></i>
                        Next: @chapter.NextDate
                    </span>

                    <span>
                        <i class="bi bi-people"></i>
                        @chapter.Members members
                    </span>
                </div>

            </div>
        }
    </div>

</div>

@code {
    public class Chapter
    {
        public string Name { get; set; }
        public string Schedule { get; set; }
        public string Time { get; set; }
        public string NextDate { get; set; }
        public int Members { get; set; }
        public string Status { get; set; }
    }

    List<Chapter> ChapterList = new()
    {
        new Chapter {
            Name="Nairobi CBD",
            Schedule="Every 2 Weeks on a Friday",
            Time="8:00am - 10:00am",
            NextDate="May 9, 2025",
            Members=120,
            Status="Active"
        },
        new Chapter {
            Name="Westlands",
            Schedule="Every 2 Weeks on a Friday",
            Time="7:30am - 9:30am",
            NextDate="Launching Soon",
            Members=0,
            Status="Coming Soon"
        },
        new Chapter {
            Name="Mombasa",
            Schedule="Monthly, Last Saturday",
            Time="9:00am - 11:00am",
            NextDate="May 31, 2025",
            Members=45,
            Status="Active"
        },
        new Chapter {
            Name="Eldoret",
            Schedule="Monthly, First Friday",
            Time="8:00am - 10:00am",
            NextDate="June 6, 2025",
            Members=38,
            Status="Active"
        },
        new Chapter {
            Name="Kisumu",
            Schedule="Bi-Monthly",
            Time="9:00am - 11:00am",
            NextDate="June 14, 2025",
            Members=22,
            Status="Active"
        },
        new Chapter {
            Name="Nakuru",
            Schedule="Quarterly",
            Time="8:30am - 10:30am",
            NextDate="July 2025",
            Members=15,
            Status="Planning"
        }
    };

    string GetBadgeClass(string status)
    {
        return status switch
        {
            "Active" => "badge-active",
            "Coming Soon" => "badge-coming",
            "Planning" => "badge-planning",
            _ => ""
        };
    }
}